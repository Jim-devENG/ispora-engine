{
  "name": "ispora-backend",
  "version": "1.0.0",
  "description": "iSpora Backend API - Robust, tested, and deployable backend service",
  "main": "src/server.js",
  "engines": {
    "node": "22.16.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "test:mongodb": "node scripts/test-mongodb.js",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "knex migrate:latest --knexfile src/knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile src/knexfile.js",
    "seed": "knex seed:run --knexfile src/knexfile.js",
    "seed:v1": "node src/scripts/seed.js",
    "migrate:phase2.1": "node src/scripts/updateMigration.js",
    "migrate:phase3": "node src/scripts/migrateProfiles.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:integration": "jest src/tests/integration.test.js --runInBand",
    "test:guardian": "jest src/tests/devops-guardian.test.js --runInBand",
    "test:pre-deploy": "node test-pre-deployment.js",
    "test:diagnose": "node diagnose-database.js",
    "guard:check": "node src/scripts/deployment-guard.js",
    "guard:pre-deploy": "npm run guard:check && npm run test:guardian && npm run test:pre-deploy",
    "pre-deploy": "npm run migrate && npm run test:pre-deploy",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "ispora",
    "backend",
    "api",
    "nodejs",
    "express",
    "postgresql",
    "knex"
  ],
  "author": "iSpora Team",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "lucide-react": "^0.552.0",
    "mongoose": "^8.19.2",
    "morgan": "^1.10.1",
    "pg": "^8.11.3",
    "pino": "^8.16.2",
    "sonner": "^2.0.7",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@sentry/node": "^7.81.1",
    "@sentry/tracing": "^7.81.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "pino-pretty": "^13.1.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/tests/**",
      "!src/knexfile.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  }
}
