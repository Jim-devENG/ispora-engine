  "dependencyGraph": {
    "frontendToBackend": {
      "CreateProject.tsx": [
        "POST /api/v1/projects (projectsMongoose.js)"
      ],
      "MyProjects.tsx": [
        "GET /api/v1/projects?mine=true (projectsMongoose.js)",
        "GET /api/v1/projects/updates?mine=true (projectsMongoose.js)"
      ],
      "Dashboard.tsx": [
        "GET /api/feed (feed.js)",
        "GET /api/feed/stream (feed.js - SSE)",
        "POST /api/feed/activity (feed.js)"
      ],
      "TaskManager.tsx": [
        "GET /api/v1/tasks/project/:projectId (tasksMongoose.js)",
        "POST /api/v1/tasks (tasksMongoose.js)",
        "PATCH /api/v1/tasks/:id/status (tasksMongoose.js)"
      ],
      "NotificationsPage.tsx": [
        "GET /api/v1/notifications (notifications.js - Phase 2) ❌",
        "PUT /api/v1/notifications/:id/read (notifications.js - Phase 2) ❌"
      ],
      "OpportunitiesPage.tsx": [
        "GET /api/v1/opportunities (opportunities.js - Phase 2) ❌"
      ],
      "CreditsPage.tsx": [
        "GET /api/v1/credits/overview (credits.js - Phase 3) ❌",
        "GET /api/v1/credits/badges (credits.js - Phase 3) ❌",
        "GET /api/v1/credits/leaderboard (credits.js - Phase 3) ❌"
      ],
      "MyNetwork.tsx": [
        "GET /api/v1/network/discovery (network.js - Phase 3) ❌",
        "POST /api/v1/network/connections/requests (network.js - Phase 3) ❌"
      ],
      "AdminDashboard.tsx": [
        "GET /api/v1/admin/stats (admin.js - Phase 6) ❌",
        "GET /api/v1/admin/users (admin.js - Phase 6) ❌"
      ]
    },
    "backendToDatabase": {
      "projectsMongoose.js": [
        "Project.create() (MongoDB)",
        "Project.find() (MongoDB)",
        "ProjectUpdate.find() (MongoDB)"
      ],
      "tasksMongoose.js": [
        "Task.create() (MongoDB)",
        "Task.find() (MongoDB)",
        "Task.findByIdAndUpdate() (MongoDB)"
      ],
      "feed.js": [
        "db('feed_entries').select() (SQLite/PostgreSQL)",
        "db('feed_entries').insert() (SQLite/PostgreSQL)"
      ]
    },
    "dataFlow": {
      "Project Creation": [
        "Frontend (CreateProject.tsx)",
        "→ POST /api/v1/projects",
        "→ projectsMongoose.js (createProject)",
        "→ Objectives Normalization (string → array)",
        "→ Project.create() (MongoDB)",
        "→ Response (project object)",
        "→ Frontend (refreshFeed + refreshProjects events)"
      ],
      "Feed Updates (SSE)": [
        "Frontend (FeedService.tsx)",
        "→ GET /api/feed/stream?token=xxx (EventSource)",
        "→ feed.js (SSE stream)",
        "→ db('feed_entries').select() (SQLite/PostgreSQL)",
        "→ Stream messages (connected, welcome, ping, message)",
        "→ Frontend (handleRealtimeUpdate)"
      ],
      "Task Management": [
        "Frontend (TaskManager.tsx)",
        "→ POST /api/v1/tasks",
        "→ tasksMongoose.js (createTask)",
        "→ Project ownership validation",
        "→ Task.create() (MongoDB)",
        "→ Response (task object)",
        "→ Frontend (task list update)"
      ]
    }
  }
}

