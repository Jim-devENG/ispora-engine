# Environment Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
# For development (SQLite)
DB_CLIENT=sqlite3
# For production (PostgreSQL)
# DATABASE_URL=postgresql://username:password@host:port/database

# MongoDB Configuration (Phase 1+ - Required for /api/v1/* routes)
# For development (local)
MONGO_URI=mongodb://localhost:27017/ispora
# For production (MongoDB Atlas)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ispora
# Alternative: Use MONGODB_URI
# MONGODB_URI=mongodb://localhost:27017/ispora

# JWT Configuration (Required)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration
CLIENT_URL=https://ispora.app

# Logging
LOG_LEVEL=info

# Sentry (Optional)
SENTRY_DSN=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Seed Configuration (Optional)
# Set CLEAR_SEED=true to clear existing data before seeding (development only)
CLEAR_SEED=false

# Phase 2.1: Email Notifications (Optional)
# Set SUPPORT_EMAIL_NOTIFICATIONS=true to enable email notifications (not yet implemented)
SUPPORT_EMAIL_NOTIFICATIONS=false
