# iSpora Health Monitor Configuration
# Copy this to .env and customize for your setup

# Monitor Configuration
HEALTH_URL=https://ispora-backend.onrender.com
CHECK_INTERVAL=30000
ALERT_THRESHOLD=5000
LOG_FILE=./logs/health-monitor.log

# Optional: Slack Webhook for Alerts
# WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Optional: Custom Render URL
# HEALTH_URL=https://your-custom-domain.com

